a = int(input("Введите число: "))
for b in range(2, a):
    if a % b == 0:
        print("Составное")
        break
else:
    print("Простое")


for a in range(1, 11):
    for b in range(1, 11):
        print(f"{a} * {b} = {a*b:>4}", end='\t')
    print()



start = int(input("Начальное число: "))
stop = int(input("Конечное число: "))
for a in range(start, stop + 1):
    for b in range(1, 11):
        print(f"{a} * {b} = {a*b}", end='\t')
    print()
